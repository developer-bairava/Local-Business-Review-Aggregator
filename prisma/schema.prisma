// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Business {
  id          String   @id @default(cuid())
  name        String
  address     String
  city        String
  state       String
  zip         String?
  country     String  @default("US")
  lat         Float
  lng         Float
  category    String
  phone       String?
  website     String?
  hours       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources          ReviewSource[]
  aggregatedScore  AggregatedScore?

  @@index([lat, lng])
  @@index([category])
  @@index([name])
}

model ReviewSource {
  id          String   @id @default(cuid())
  businessId  String
  platform    String   // "google" | "yelp" | "tripadvisor" | "foursquare"
  externalId  String
  url         String?
  lastSynced  DateTime?
  createdAt   DateTime @default(now())

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  reviews     Review[]

  @@unique([businessId, platform])
  @@index([businessId])
}

model Review {
  id         String   @id @default(cuid())
  sourceId   String
  businessId String
  platform   String
  rating     Float
  text       String?
  author     String?
  authorUrl  String?
  date       DateTime
  verified   Boolean  @default(false)
  createdAt  DateTime @default(now())

  source     ReviewSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([platform])
  @@index([date])
}

model AggregatedScore {
  id            String   @id @default(cuid())
  businessId    String   @unique
  avgRating     Float
  totalReviews  Int
  googleRating  Float?
  googleCount   Int?
  yelpRating    Float?
  yelpCount     Int?
  otherRating   Float?
  otherCount    Int?
  lastSynced    DateTime @default(now())

  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  userReviews   UserReview[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model UserReview {
  id         String   @id @default(cuid())
  businessId String
  userId     String
  rating     Float
  text       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([businessId])
  @@unique([userId, businessId])
}
